{
  "name": "ironlock-xyz",
  "version": "1.0.0",
  "description": "IronLock — BNB Chain rugpull-proof launchpad",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "hh:compile": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat compile",
    "hh:deploy": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run deploy/deploy.ts --network bscTestnet",
    "hh:deploy:mainnet": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run deploy/deploy.ts --network bsc",
    "hh:test": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat test",
    "hh:verify": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat verify --network bscTestnet",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run deploy/deploy.ts --network bsc",
    "deploy:testnet": "hardhat run deploy/deploy.ts --network bscTestnet",
    "verify": "hardhat verify --network bsc",
    "verify:testnet": "hardhat verify --network bscTestnet",
    "node": "hardhat node",
    "clean": "hardhat clean && rm -rf .next node_modules/.cache"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@tanstack/react-query": "^5.101.1",
    "lucide-react": "^1.21.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "viem": "^2.21.0",
    "wagmi": "^2.12.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.0",
    "@openzeppelin/hardhat-upgrades": "^3.5.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.2.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "chai": "^4.2.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^8",
    "eslint-config-next": "^14.2.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^1.0.10",
    "postcss": "^8.4.47",
    "solidity-coverage": "^0.8.12",
    "tailwindcss": "^3.4.13",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.0",
    "typescript": "^5.9.3"
  }
}
